# Zendesk JWT Authentication Environment Variables
# Copy this file to .env and fill in your values.
#
# These can ALSO be configured via /setup.html after deployment.
# Env vars take priority over the setup page.

# Required: Your Zendesk JWT Shared Secret
# Found in Zendesk Admin → Channels → Messaging → Settings → JWT Authentication
ZENDESK_JWT_SECRET=

# Required: Your Zendesk Key ID (kid)
# Found in Zendesk Admin → Channels → Messaging → Settings → JWT Authentication
ZENDESK_KID=

# Required: Your Zendesk Web Widget Key
# Found in Zendesk Admin → Channels → Messaging → Web Widget (key=... in the snippet)
ZENDESK_WIDGET_KEY=

# Optional: Your Zendesk subdomain
ZENDESK_ACCOUNT=

# Server port (default: 3000)
PORT=3000
NODE_ENV=development